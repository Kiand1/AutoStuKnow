# -------------------- NAS / Docker --------------------
# 建议改成 NAS 上的绝对路径，例如 /volume1/docker/autostuknow
DATA_ROOT=./data
BIND_ADDRESS=0.0.0.0
PUID=1000
PGID=1000
TZ=Asia/Shanghai

# 首次部署前必须替换。可用：openssl rand -hex 32
ANYTHINGLLM_JWT_SECRET=replace-with-a-random-secret
N8N_ENCRYPTION_KEY=replace-with-a-different-random-secret
INGESTOR_API_KEY=replace-with-a-third-random-secret
WEBHOOK_API_KEY=replace-with-a-fourth-random-secret
WEB_UI_USERNAME=admin
WEB_UI_PASSWORD=replace-with-a-web-ui-password
WEB_UI_SESSION_SECRET=replace-with-a-web-ui-session-secret
WEB_UI_SESSION_TTL_HOURS=24
# 直接使用 HTTP 访问 NAS 时为 false；配置 HTTPS 反向代理后改为 true。
WEB_UI_SECURE_COOKIE=false

# -------------------- Images / ports --------------------
ANYTHINGLLM_IMAGE=mintplexlabs/anythingllm:latest
N8N_IMAGE=n8nio/n8n:2.30.5
WHISPER_IMAGE=hwdsl2/whisper-server:latest
ANYTHINGLLM_PORT=3001
N8N_PORT=5678
INGESTOR_PORT=8090

# 浏览器访问 n8n 时使用的完整地址，结尾保留 /
N8N_PUBLIC_URL=http://192.168.1.100:5678/
# 直接使用 HTTP 访问 NAS 时设为 false；配置 HTTPS 反向代理后改为 true。
N8N_SECURE_COOKIE=false

# -------------------- Faster Whisper --------------------
# CPU NAS 建议 base 或 small；内存紧张用 tiny/base，准确率优先用 small/medium。
WHISPER_MODEL=base
WHISPER_LANGUAGE=auto
WHISPER_COMPUTE_TYPE=int8
WHISPER_THREADS=4
WHISPER_API_KEY=

# 单条视频限制，避免误提交超长直播或撑满 NAS。
MAX_VIDEO_DURATION_MINUTES=180
MAX_DOWNLOAD_SIZE_MB=1024
MAX_CONCURRENT_JOBS=1
# 默认转录成功后删除下载的音频，节省 NAS 空间；需要审计原始音频时改为 true。
KEEP_AUDIO=false

# 需要登录、会员或年龄验证的视频可挂载 Netscape 格式 cookies 文件。
# 先复制 config/yt-cookies.txt.example 为 config/yt-cookies.txt，再取消下一行注释。
YTDLP_COOKIES_FILE=
# 优先使用人工字幕，其次 YouTube 自动字幕；都不可用时才调用 Whisper。
PREFER_YOUTUBE_SUBTITLES=true
ALLOW_AUTOMATIC_SUBTITLES=true

# -------------------- OpenAI-compatible summarizer --------------------
# 留空 LLM_BASE_URL 或 LLM_MODEL 时会跳过 AI 总结，但仍保留并导入完整转录。
# OpenAI: https://api.openai.com/v1
# Ollama: http://host.docker.internal:11434/v1
# 其他 OpenAI 兼容服务也填到 /v1。
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# DeepSeek V4 做结构化摘要时建议关闭思考模式并启用 JSON Output；其他服务不支持时留空/false。
LLM_THINKING_MODE=
LLM_JSON_MODE=false
SUMMARY_LANGUAGE=zh-CN
LLM_CHUNK_CHARS=12000
LLM_MAX_TOKENS=1800

# -------------------- AnythingLLM API --------------------
# 设为 deepseek 时，AnythingLLM 会复用上面的 LLM_API_KEY 与 LLM_MODEL。
ANYTHINGLLM_LLM_PROVIDER=
# 中文知识库建议使用内置多语言模型；首次使用会下载约 487MB。
ANYTHINGLLM_EMBEDDING_MODEL=MintplexLabs/multilingual-e5-small
# 第一次启动后在 AnythingLLM 中完成引导、创建 workspace 和 API Key，再填写下面两项。
ANYTHINGLLM_API_KEY=
ANYTHINGLLM_WORKSPACE_SLUG=
ANYTHINGLLM_AUTO_SYNC=true
# 首次下载多语言模型或导入长文档时需要更长的同步等待时间。
ANYTHINGLLM_SYNC_TIMEOUT_SECONDS=1800
